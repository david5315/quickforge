            { title: "机房火灾/冒烟切断机柜电", desc: "热成像或烟雾识别，自动切断对应机柜PDU电源并启动气体灭火。", icon: "🖧", category: "industry", tag: "数据中心" },
            { title: "实验室气体泄漏切断阀门", desc: "识别有色气体泄漏或火焰，自动切断气路电磁阀，打开防爆风机。", icon: "🧪", category: "industry", tag: "实验室安全" },
            { title: "工地安全帽识别闸机控制", desc: "未戴安全帽人员禁止进入工地，闸机保持锁定。", icon: "⛑️", category: "industry", tag: "工地管理" },
            { title: "危化品仓库泄漏全屋断电", desc: "检测液体泄漏或挥发烟雾，立即切断非本安电路并强力排风。", icon: "☣️", category: "industry", tag: "危化管理" },
            { title: "设备冒火花自动断电灭火", desc: "高频闪烁识别电火花，毫秒级切断该区域总电源并启动灭火装置。", icon: "⚡", category: "industry", tag: "工业安全" },
            { title: "工厂照明按人员分区控制", desc: "视觉定位人员位置，自动开启所在区域照明，无人区域自动熄灯。", icon: "🏭", category: "industry", tag: "节能管理" },
            { title: "鱼塘浮头缺氧自动增氧", desc: "识别鱼群浮头行为，自动开启增氧机电源，避免泛塘。", icon: "🐟", category: "agriculture", tag: "水产养殖" },
            { title: "温室高温自动遮阳通风", desc: "温度+视觉判断作物状态，自动开启遮阳电机、风机水帘电源。", icon: "🌡️", category: "agriculture", tag: "设施农业" },
            { title: "猪只打架自动喷水干预", desc: "识别猪只激烈打斗，启动上方喷水电磁阀，分散注意力。", icon: "🐖", category: "agriculture", tag: "畜牧养殖" },
            { title: "鸡群状态异常调光照通风", desc: "分析鸡群活跃度、扎堆情况，自动调整光照强度和通风设备。", icon: "🐔", category: "agriculture", tag: "禽类养殖" },
            { title: "挤奶机视觉自动启动", desc: "检测奶牛进入挤奶位并静止，自动启动挤奶设备。", icon: "🐄", category: "agriculture", tag: "畜牧养殖" },
            { title: "果园虫害识别精准喷药", desc: "AI识别叶片虫害特征，控制对应区域的喷药电磁阀，精准施药。", icon: "🍎", category: "agriculture", tag: "精准农业" },
            { title: "作物萎蔫视觉判断灌溉", desc: "视觉分析叶片下垂、土壤颜色，自动开启滴灌电磁阀补水。", icon: "🌱", category: "agriculture", tag: "智慧灌溉" },
            { title: "病人坠床自动呼叫断电", desc: "病房监控检测病人坠床或异常离床，呼叫护士站并切断附近非医疗电器。", icon: "🛌", category: "healthcare", tag: "病人安全" },
            { title: "输液完毕自动关泵", desc: "视觉监测输液袋/瓶液面，液体流尽自动关闭输液泵并通知。", icon: "💉", category: "healthcare", tag: "智慧病房" },
            { title: "新生儿室未授权闯入锁门", desc: "识别非授权人员进入，立即锁定区域门禁并触发安保。", icon: "👶", category: "healthcare", tag: "婴儿安全" },
            { title: "精神科自残行为切断风险电源", desc: "识别自伤行为，切断该病房非安全电器并呼叫约束。", icon: "🧠", category: "healthcare", tag: "精神科安防" },
            { title: "药房偷药锁定柜门", desc: "识别偷窃管制药品行为，触发磁力锁锁住药柜并报警。", icon: "💊", category: "healthcare", tag: "药品管理" },
            { title: "手术室未消毒禁入控制", desc: "识别人员未按消毒流程进入手术室区域，门禁保持锁定。", icon: "🏥", category: "healthcare", tag: "手术安全" },
            { title: "办公室下班无人自动断电", desc: "区域视觉检测最后一人离开，自动切断照明、空调、插座电源。", icon: "💼", category: "office", tag: "办公节能" },
            { title: "智能教室无人断电", desc: "教室监控识别无学生后，自动关闭多媒体、灯光、空调电源。", icon: "🏫", category: "office", tag: "校园节能" },
            { title: "共享工位电源视觉控制", desc: "检测到人员入座自动通电，离开后延时断电，实现工位电源管理。", icon: "🪑", category: "office", tag: "共享办公" },
            { title: "会议室无人关投影仪", desc: "会议室监控识别人员全部离场，自动关闭投影仪、幕布电机和灯光。", icon: "📽️", category: "office", tag: "办公节能" },
            { title: "考场作弊屏蔽器电源控制", desc: "检测到作弊行为（如拿出手机），自动激活该区域信号屏蔽器电源。", icon: "📵", category: "office", tag: "教育安防" },
            { title: "隧道火灾自动喷淋排风", desc: "摄像头识别隧道内明火或浓烟，自动启动喷淋泵和射流风机电源。", icon: "🚇", category: "transport", tag: "隧道安全" },
            { title: "桥梁结冰启动融雪装置", desc: "视觉识别桥面结冰或积雪，自动接通融雪电缆或喷洒融雪剂泵。", icon: "🌉", category: "transport", tag: "道路安全" },
            { title: "公交站人多启动空调亭", desc: "识别候车亭人群密度>某值，自助开启空调风扇/暖风机电源。", icon: "🚌", category: "transport", tag: "公共交通" },
            { title: "光伏板脏污自动清洗", desc: "无人机或固定摄像头识别光伏板积灰、鸟粪，启动清洗机器人行走和喷水。", icon: "☀️", category: "transport", tag: "新能源运维" },
            { title: "地铁站台越线锁定屏蔽门", desc: "识别乘客越过黄线或进入轨道区域，立即锁定屏蔽门并广播警告。", icon: "🚉", category: "transport", tag: "轨交安全" }
        ];

        // 确保正好50个，如果不够可补充，但当前数据为50条
        function renderScenes(filter = 'all') {
            const grid = document.getElementById('sceneGrid');
            const filtered = filter === 'all' ? scenes : scenes.filter(s => s.category === filter);
            grid.innerHTML = filtered.map((scene, idx) => {
                // 类别对应的标签样式类
                const tagClass = `category-tag tag-${scene.category}`;
                return `
                <div class="scene-card" data-category="${scene.category}">
                    <span class="scene-number">#${idx + 1}</span>
                    <div class="card-header">
                        <div class="scene-icon">${scene.icon}</div>
                        <span class="${tagClass}">${scene.tag}</span>
                    </div>
                    <h3 class="scene-title">${scene.title}</h3>
                    <p class="scene-desc">${scene.desc}</p>
                </div>`;
            }).join('');
            document.getElementById('sceneCounter').textContent = `显示 ${filtered.length} 个场景`;
        }

        // 筛选按钮事件
        document.querySelectorAll('.filter-btn').forEach(btn => {
            btn.addEventListener('click', function() {
                document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
                this.classList.add('active');
                const filter = this.dataset.filter;
                renderScenes(filter);
            });
        });

        // 初始渲染
        renderScenes('all');
    </script>

</body></html>